{
  "manifest_version": 3,
  "name": "Brave Tab Manager",
  "version": "1.0",
  "permissions": ["tabs", "webNavigation", "storage", "tabGroups"],
  "background": {
    "service_worker": "main.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": ["*://*/*"]
}
